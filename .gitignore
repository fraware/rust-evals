# Ephemeral local experiment dirs (never commit)
runs/tmp_*/

# Local run artifacts (released runs live in runs/released and MAY be committed)
runs/local/**
!runs/local/.gitkeep
runs/ci/**
!runs/ci/.gitkeep

# Shared Cargo target cache for local batch recipes (`just verified-batch-optimized`, etc.)
runs/released/.eval_ladder_cargo_cache/

# Local-only rerun artifacts from gold-patch validation (keep out of commits)
runs/released/l2_verified_flagship_v1/gold_patch_results/results_astropy/
runs/released/l2_verified_flagship_v1/gold_patch_results/results_regressionfail/

# Large benchmark assets pulled from public sources
datasets/cache/
benchmarks/**/workdir/

# Secrets
.env
.env.*
!.env.example
secrets/
*.pem
*.key

# Local release / submission scratch (never commit)
/CI_LOG.txt
/*.tar.gz

# Paper exports, tables, and manuscript-facing material (generate locally; do not commit)
paper/
