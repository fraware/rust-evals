{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eval-ladder.dev/schemas/evidence_bundle.schema.json",
  "title": "EvidenceBundle",
  "description": "Reproducible bundle for a single evaluated candidate. The bundle index enumerates every file plus its SHA-256 digest and size.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "candidate_id",
    "task_id",
    "benchmark_id",
    "created_by_version",
    "created_at",
    "files",
    "bundle_hash"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "bundle_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "task_id": { "type": "string", "minLength": 1 },
    "benchmark_id": {
      "type": "string",
      "enum": ["swe_bench_verified", "swe_bench_live", "rust_swe_bench"]
    },
    "created_by_version": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": {
            "type": "string",
            "description": "POSIX path relative to the bundle root."
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "bundle_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "sha256 over the canonical JSON of the bundle minus the bundle_hash field itself."
    },
    "required_members_present": {
      "type": "array",
      "description": "Which mandatory bundle members were present. Used by verifiers.",
      "items": {
        "type": "string",
        "enum": [
          "candidate_resolution.json",
          "run_manifest.json",
          "trace.jsonl",
          "official_results.json",
          "strengthened_results.json",
          "policy_results.json",
          "proof_results.json",
          "patch.diff",
          "container_metadata.json",
          "stdout.log",
          "stderr.log",
          "artifact_hashes.json"
        ]
      },
      "uniqueItems": true
    }
  }
}
