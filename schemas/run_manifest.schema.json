{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eval-ladder.dev/schemas/run_manifest.schema.json",
  "title": "RunManifest",
  "description": "Single-run metadata. One per candidate per evaluator invocation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "candidate_id",
    "task_id",
    "benchmark_id",
    "levels_requested",
    "evaluator_version",
    "container_metadata",
    "started_at",
    "finished_at",
    "status"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "task_id": { "type": "string", "minLength": 1 },
    "benchmark_id": {
      "type": "string",
      "enum": ["swe_bench_verified", "swe_bench_live", "rust_swe_bench"]
    },
    "levels_requested": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["L0", "L1", "L2", "L3", "L4"]
      }
    },
    "evaluator_version": { "type": "string", "minLength": 1 },
    "container_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "image", "image_digest"],
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["docker", "podman", "containerd", "other"]
        },
        "image": { "type": "string", "minLength": 1 },
        "image_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "cpu_limit": { "type": ["string", "null"] },
        "memory_limit": { "type": ["string", "null"] },
        "network_mode": {
          "type": "string",
          "enum": ["disabled", "host_allowlist", "none"]
        }
      }
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["completed", "aborted", "errored"]
    }
  }
}
